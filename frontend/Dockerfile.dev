# Frontend Development Dockerfile
FROM node:20-alpine

# Install additional tools for development
RUN apk add --no-cache bash

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start in development mode
CMD ["npm", "run", "dev"]
